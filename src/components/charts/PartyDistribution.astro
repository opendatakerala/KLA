---
---

<div class="party-pies" id="party-pies">
  <div class="pie-wrapper">
    <div class="pie-label">LDF</div>
    <div class="pie-chart" id="pie-chart-ldf"></div>
  </div>
  <div class="pie-wrapper">
    <div class="pie-label">UDF</div>
    <div class="pie-chart" id="pie-chart-udf"></div>
  </div>
  <div class="pie-wrapper">
    <div class="pie-label">NDA</div>
    <div class="pie-chart" id="pie-chart-nda"></div>
  </div>
  <div class="pie-wrapper">
    <div class="pie-label">Others</div>
    <div class="pie-chart" id="pie-chart-others"></div>
  </div>
</div>

<script>
  import * as echarts from 'echarts';
  import candidatesByParty from '../../data/candidates-by-party.json';

  const PARTY_PALETTE = [
    '#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd', 
    '#8c564b', '#e377c2', '#7f7f7f', '#bcbd22', '#17becf',
    '#aec7e8', '#ffbb78', '#98df8a', '#ff9896', '#c5b0d5',
    '#c49c94', '#f7b6d2', '#c7c7c7', '#dbdb8d', '#9edae5'
  ];

  function renderPartyPie(alliance, containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const parties = candidatesByParty[alliance] || {};
    const data = Object.entries(parties)
      .map(([name, value], idx) => ({
        name,
        value,
        itemStyle: { color: PARTY_PALETTE[idx % PARTY_PALETTE.length] }
      }))
      .sort((a, b) => b.value - a.value);

    const chart = echarts.init(container, null, { renderer: 'svg' });
    
    const option = {
      tooltip: {
        trigger: 'item',
        formatter: '{b}: {c} ({d}%)'
      },
      legend: {
        type: 'scroll',
        orient: 'vertical',
        right: 5,
        top: 'center',
        bottom: 10,
        width: 80,
        textStyle: { fontFamily: 'DM Mono', fontSize: 9 },
        pageTextStyle: { fontFamily: 'DM Mono', fontSize: 9 }
      },
      series: [{
        type: 'pie',
        radius: ['30%', '65%'],
        center: ['35%', '50%'],
        label: {
          show: true,
          formatter: '{b}\n{c}',
          fontSize: 9,
          fontFamily: 'DM Mono',
          lineHeight: 12,
          padding: [2, 0, 0, 0]
        },
        labelLine: { show: false },
        emphasis: {
          itemStyle: {
            shadowBlur: 10,
            shadowOffsetX: 0,
            shadowColor: 'rgba(0, 0, 0, 0.5)'
          }
        },
        data
      }]
    };

    chart.setOption(option);
    return chart;
  }

  function init() {
    const charts = [
      renderPartyPie('LDF', 'pie-chart-ldf'),
      renderPartyPie('UDF', 'pie-chart-udf'),
      renderPartyPie('NDA', 'pie-chart-nda'),
      renderPartyPie('Others', 'pie-chart-others')
    ];

    window.addEventListener('resize', () => {
      charts.forEach(c => c && c.resize());
    });
  }

  document.addEventListener('DOMContentLoaded', init);
</script>

<style>
  .party-pies {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .party-pies {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .party-pies {
      grid-template-columns: 1fr;
    }
  }

  .pie-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pie-label {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    color: var(--text-soft);
  }

  .pie-chart {
    width: 100%;
    height: 300px;
  }
</style>